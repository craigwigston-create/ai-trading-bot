# ============================================
# ALPACA API CONFIGURATION
# ============================================
# Get these from https://alpaca.markets
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here

# Paper trading (simulated money) vs live trading
# https://paper-api.alpaca.markets for paper trading
# https://api.alpaca.markets for live trading
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ============================================
# TRADING PARAMETERS
# ============================================
# Which stock/crypto to trade
SYMBOL=AAPL

# How many shares to buy per trade
POSITION_SIZE=10

# Maximum % of account to risk per trade (2% = 0.02)
MAX_RISK_PER_TRADE=0.02

# Stop loss: exit if price drops X% (5% = 0.05)
STOP_LOSS_PERCENT=0.05

# Maximum daily loss before stopping (10% = 0.10)
MAX_DAILY_DRAWDOWN=0.10

# Only trade if model is this confident (75% = 0.75)
CONFIDENCE_THRESHOLD=0.75

# ============================================
# MODEL PARAMETERS
# ============================================
# Where to save/load trained models
MODEL_PATH=data/models/trading_model.pkl

# Training data: how many years back
TRAINING_YEARS=2

# How often to run (in minutes)
INTERVAL_MINUTES=60

# ============================================
# LOGGING
# ============================================
# Where to save logs
LOG_FILE=trading.log

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================
# DATABASE (Optional)
# ============================================
# SQLite database for storing trades
DATABASE_PATH=data/trading.db

# ============================================
# EMAIL ALERTS (Optional)
# ============================================
# Get alerts when trades happen
SEND_EMAIL_ALERTS=false
EMAIL_FROM=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_TO=alerts@example.com
